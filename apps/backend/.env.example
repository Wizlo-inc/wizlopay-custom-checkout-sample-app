# WizloPay credentials
WIZLOPAY_INSTANCE_ID=
WIZLOPAY_API_KEY=your-api-key
WIZLOPAY_PRIVATE_KEY_ID=
# ES512 private key — paste the full PEM including header/footer on one line with \n
WIZLOPAY_PRIVATE_KEY=""
WIZLOPAY_WEBHOOK_SECRET=your-webhook-secret
WIZLOPAY_ENVIRONMENT=sandbox
WIZLOPAY_MERCHANT_ACCOUNT_ID=

# Plaid (via gr4vy payment service)
WIZLOPAY_PLAID_SERVICE_ID=

# Stripe (for Link embedded checkout)
STRIPE_SECRET_KEY=sk_test_...

# App
APP_DOMAIN=localhost:3000
APP_PORT=4000
FRONTEND_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wizlopay_checkout
